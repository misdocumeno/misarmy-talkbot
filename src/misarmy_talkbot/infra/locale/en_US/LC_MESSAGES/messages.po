msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"


msgid "follow_cmd_description"
msgstr "Make the bot start reading your messages out loud in your voice channel."

msgid "follow_success"
msgstr "Ok, I will read your messages out loud!"

msgid "already_following"
msgstr "I'm already reading your messages!"

msgid "not_in_voice_channel"
msgstr "You are not in a voice channel!"

msgid "not_in_same_voice_channel"
msgstr "We are not on the same channel!"


msgid "unfollow_cmd_description"
msgstr "Stops the bot from reading your messages out loud in your voice channel."

msgid "unfollow_success"
msgstr "I won't read your messages anymore."

msgid "not_following"
msgstr "I'm not reading your messages!"


msgid "ignore_cmd_description"
msgstr "Toggle between reading and ignoring your messages in this channel if the bot is following you."

msgid "ignore_success"
msgstr "I will ignore your messages on this channel from now on."

msgid "un_ignore_success"
msgstr "I will read your messages on this channel again!"


msgid "stop_cmd_description"
msgstr "Stops the bot from reading aloud the current and following messages (only your messages)."

msgid "stop_all_cmd_description"
msgstr "Stops the bot from reading aloud the current and following messages. Everyone's messages!"

msgid "not_talking"
msgstr "I'm not talking."

msgid "shut_up_success"
msgstr "Ok I'll stop, sorry..."


msgid "skip_cmd_description"
msgstr "Makes the bot skip to the the next message."

msgid "skip_no_permission"
msgstr "You can only skip your own messages."


msgid "mute_cmd_description"
msgstr "Stop reading someone's messages."

msgid "mute_cmd_target_argument_description"
msgstr "The person to stop reading their messages."


msgid "voice_cmd_description"
msgstr "Change your current voice."

msgid "voice_cmd_new_voice_argument_description"
msgstr "The new voice you want."

msgid "voice_cmd_current_voice"
msgstr "Your current voice is {voice}"

msgid "voice_cmd_invalid_voice"
msgstr "That voice does not exist!"

msgid "voice_cmd_same_voice"
msgstr "You already have that voice!"

msgid "voice_cmd_new_voice"
msgstr "Now your voice will be {voice}"

msgid "voice_cmd_new_voice_footer"
msgstr "Your pitch and speed have been restored to 1.0"


msgid "pitch_cmd_description"
msgstr "Change your current voice pitch."

msgid "pitch_cmd_pitch_argument_description"
msgstr "The new pitch you want."

msgid "pitch_cmd_current_pitch"
msgstr "Your current voice pitch is {pitch}"

msgid "pitch_cmd_same_pitch"
msgstr "You already have that voice pitch!"

msgid "pitch_cmd_new_pitch"
msgstr "Now your voice pitch will be {pitch}"


msgid "speed_cmd_description"
msgstr "Change your current voice speed."

msgid "speed_cmd_speed_argument_description"
msgstr "The new speed you want."

msgid "speed_cmd_current_speed"
msgstr "Your current voice speed is {speed}"

msgid "speed_cmd_same_speed"
msgstr "You already have that voice speed!"

msgid "speed_cmd_new_speed"
msgstr "Now your voice speed will be {speed}"


msgid "preset_cmd_description"
msgstr "Save your current voice settings as a preset, or load an existing one."

msgid "preset_cmd_action_argument_description"
msgstr "The action to perform."

msgid "preset_cmd_preset_name_argument_description"
msgstr "The preset name."

msgid "preset_cmd_no_preset_arg"
msgstr "You must specify a preset name!"

msgid "preset_cmd_no_presets"
msgstr "You have no saved presets."

msgid "preset_cmd_does_not_exist"
msgstr "That preset doesn't exist!"

msgid "preset_cmd_list"
msgstr "{presets}"

msgid "preset_cmd_loaded"
msgstr "Preset loaded!"

msgid "preset_cmd_saved"
msgstr "Preset saved!"

msgid "preset_cmd_deleted"
msgstr "Preset deleted!"

msgid "preset_cmd_already_exists"
msgstr "There is already a preset with that name!"


msgid "invite_cmd_description"
msgstr "Get an invite link this bot to another server."

msgid "invite_title"
msgstr "TalkBot invite"

msgid "invite_description"
msgstr "Invite this bot to another server! or join the support server."

msgid "bot_invite_button"
msgstr "Invite bot"

msgid "server_invite_button"
msgstr "Join support server"


msgid "sync_cmd_description"
msgstr "Sync all global slash commands in all guilds."

msgid "debug_cmd_description"
msgstr "Start the debugpy debugger."

msgid "debug_cmd_debugger_already_started"
msgstr "The debugger is already started!"

msgid "sync_cmd_sync_done"
msgstr "Global slash commands synchronized!"


msgid "config_cmd_description"
msgstr "Get the current guild config or update it."

msgid "config_cmd_action_argument_description"
msgstr "The action to perform."

msgid "config_cmd_set_response"
msgstr "Ok, send a new json to use as a guild config, as a code block or as a file. Make sure to mention me!"

msgid "config_cmd_set_config_updated"
msgstr "Guild's config updated!"

msgid "config_cmd_set_invalid_json"
msgstr "That json is invalid! try looking at the default config with **/config default**"

msgid "config_cmd_set_invalid_locale"
msgstr "That json is valid, but that's not a supported locale! You can contribute with a new locale to the [TalkBot repository]({repo}), or use [locale overrides]({overrides})."

msgid "config_cmd_set_invalid_locale_footer"
msgstr "You can use /locales to see the currently supported locales."

msgid "config_cmd_cancel_removed"
msgstr "Ok, I won't wait for a new guild config anymore."

msgid "config_cmd_cancel_not_waiting"
msgstr "I'm not waiting for a new guild config."

msgid "config_mention_not_waiting"
msgstr "Are you trying to update the guild's config? Try using **/config set** first."


msgid "locales_cmd_description"
msgstr "List all supported locales."

msgid "locales_cmd_list"
msgstr "{locales}"


msgid "generate_audio_failed"
msgstr "Failed to generate speech from your message! Check your voice settings."


msgid "presence_default_name"
msgstr "/follow to talk in voice"


msgid "ops_announce_title"
msgstr "Talkbot couldn't read your message"

msgid "ops_announce_phase_tts"
msgstr "Text-to-speech"

msgid "ops_announce_phase_voice"
msgstr "Voice connection"

msgid "ops_announce_phase_ffmpeg"
msgstr "Audio playback"

msgid "ops_announce_phase_playback"
msgstr "Playback"

msgid "ops_announce_phase_permissions"
msgstr "Permissions"
