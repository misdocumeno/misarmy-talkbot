msgid "follow_cmd_description"
msgstr "Hacer que el bot empiece a leer tus mensajes en voz alta en tu canal de voz."

msgid "follow_success"
msgstr "¡Bueno, voy a leer tus mensajes en voz alta!"

msgid "already_following"
msgstr "¡Ya estoy leyendo tus mensajes!"

msgid "not_in_voice_channel"
msgstr "¡No estás en un canal de voz!"

msgid "not_in_same_voice_channel"
msgstr "¡No estamos en el mismo canal!"


msgid "unfollow_cmd_description"
msgstr "Hacer que el bot deje de leer tus mensajes en voz alta en tu canal de voz."

msgid "unfollow_success"
msgstr "Ya no voy a leer tus mensajes."

msgid "not_following"
msgstr "¡No estoy leyendo tus mensajes!"


msgid "ignore_cmd_description"
msgstr "Alternar entre leer e ignorar tus mensajes en este canal si el bot te está siguiendo."

msgid "ignore_success"
msgstr "Voy a ignorar tus mensajes en este canal desde ahora."

msgid "un_ignore_success"
msgstr "¡Voy a seguir leyendo tus mensajes en este canal!"


msgid "stop_cmd_description"
msgstr "Hacer que el bot deje de leer en voz alta el mensaje actual y los que siguen (solo tus mensajes)."

msgid "stop_all_cmd_description"
msgstr "Hacer que el bot deje de leer en voz alta el mensaje actual y los que siguen (¡Los de todos!)."

msgid "not_talking"
msgstr "No estoy hablando."

msgid "shut_up_success"
msgstr "Bueno, paro, perdón..."


msgid "skip_cmd_description"
msgstr "Hacer que el bot salte al siguiente mensaje."

msgid "skip_no_permission"
msgstr "Sólo podés saltar tus propios mensajes."


msgid "mute_cmd_description"
msgstr "Dejar de leer los mensajes de alguien."

msgid "mute_cmd_target_argument_description"
msgstr "La persona a quien dejar de leer sus mensajes."


msgid "voice_cmd_description"
msgstr "Cambiar tu voz actual."

msgid "voice_cmd_new_voice_argument_description"
msgstr "La nueva voz que querés tener."

msgid "voice_cmd_current_voice"
msgstr "Tu voz actual es {voice}"

msgid "voice_cmd_invalid_voice"
msgstr "¡Esa voz no existe!"

msgid "voice_cmd_same_voice"
msgstr "¡Ya tenés esa voz!"

msgid "voice_cmd_new_voice"
msgstr "Ahora tu voz va a ser {voice}"

msgid "voice_cmd_new_voice_footer"
msgstr "Tu tono de voz y velocidad se restauraron a 1.0"


msgid "pitch_cmd_description"
msgstr "Cambiar tu tono de voz actual."

msgid "pitch_cmd_pitch_argument_description"
msgstr "El nuevo tono de voz que querés tener."

msgid "pitch_cmd_current_pitch"
msgstr "Tu tono de voz actual es {pitch}"

msgid "pitch_cmd_same_pitch"
msgstr "¡Ya tenés ese tono de voz!"

msgid "pitch_cmd_new_pitch"
msgstr "Ahora tu tono de voz va a ser {pitch}"


msgid "speed_cmd_description"
msgstr "Cambiar tu velocidad de voz actual."

msgid "speed_cmd_speed_argument_description"
msgstr "La nueva velocidad que querés tener."

msgid "speed_cmd_current_speed"
msgstr "Tu velocidad de voz actual es {speed}"

msgid "speed_cmd_same_speed"
msgstr "¡Ya tenés esa velocidad de voz!"

msgid "speed_cmd_new_speed"
msgstr "Ahora la velocidad de tu voz va a ser {speed}"


msgid "preset_cmd_description"
msgstr "Guardar tu configuración de voz actual como preset, o cargar uno existente."

msgid "preset_cmd_action_argument_description"
msgstr "La acción a realizar."

msgid "preset_cmd_preset_name_argument_description"
msgstr "El nombre del preset."

msgid "preset_cmd_no_preset_arg"
msgstr "¡Tenés que especificar un preset!"

msgid "preset_cmd_no_presets"
msgstr "No tenés presets guardados."

msgid "preset_cmd_does_not_exist"
msgstr "¡Ese preset no existe!"

msgid "preset_cmd_list"
msgstr "{presets}"

msgid "preset_cmd_loaded"
msgstr "¡Preset cargado!"

msgid "preset_cmd_saved"
msgstr "¡Preset guardado!"

msgid "preset_cmd_deleted"
msgstr "¡Preset borrado!"

msgid "preset_cmd_already_exists"
msgstr "¡Ya existe un preset con ese nombre!"


msgid "invite_cmd_description"
msgstr "Generar un link de invitación para meter a este bot en otro servidor."

msgid "invite_title"
msgstr "Invitar a TalkBot"

msgid "invite_description"
msgstr "¡Invitá a este bot a otro servidor! o unite al servidor de soporte."

msgid "bot_invite_button"
msgstr "Invitar bot"

msgid "server_invite_button"
msgstr "Unirse al servidor"


msgid "sync_cmd_description"
msgstr "Sincronizar todos los comandos slash en todas las guilds."

msgid "debug_cmd_description"
msgstr "Iniciar el debugger de debugpy."

msgid "debug_cmd_debugger_already_started"
msgstr "¡El debugger ya está iniciado!"

msgid "sync_cmd_sync_done"
msgstr "¡Comandos slash globales sincronizados!"


msgid "config_cmd_description"
msgstr "Ver la configuración actual del servidor o cambiarla."

msgid "config_cmd_action_argument_description"
msgstr "La acción a realizar."

msgid "config_cmd_set_response"
msgstr "Bueno, enviá un nuevo json para usarlo como configuración de servidor, como bloque de código o como archivo. ¡No te olvidés de mencionarme!"

msgid "config_cmd_set_config_updated"
msgstr "¡Configuración del servidor actualizada!"

msgid "config_cmd_set_invalid_json"
msgstr "¡Ese json no es válido! Intentá ver la configuración predeterminada con **/config default**"

msgid "config_cmd_set_invalid_locale"
msgstr "Ese json es válido, ¡pero ese no es un locale soportado! Podés contribuir con un locale nuevo al [repository de TalkBot]({repo}), o usar [locale overrides]({overrides})."

msgid "config_cmd_set_invalid_locale_footer"
msgstr "Podés usar /locales para ver los locales actualmente soportados."

msgid "config_cmd_cancel_removed"
msgstr "Bueno, no voy a esperar más una nueva configuración de servidor."

msgid "config_cmd_cancel_not_waiting"
msgstr "No estoy esperando una nueva configuración de servidor."

msgid "config_mention_not_waiting"
msgstr "¿Estás intentando actualizar la configuración del servidor? Probá usar **/config set** primero."


msgid "locales_cmd_description"
msgstr "Listar todos los locales soportados."

msgid "locales_cmd_list"
msgstr "{locales}"


msgid "generate_audio_failed"
msgstr "¡No se pudo generar el audio de tu mensaje! Revisá tu configuración de voz."


msgid "presence_default_name"
msgstr "/follow para hablar en voz"


msgid "ops_announce_title"
msgstr "Talkbot no pudo leer tu mensaje"

msgid "ops_announce_phase_tts"
msgstr "Texto a voz"

msgid "ops_announce_phase_voice"
msgstr "Conexión de voz"

msgid "ops_announce_phase_ffmpeg"
msgstr "Reproducción de audio"

msgid "ops_announce_phase_playback"
msgstr "Reproducción"

msgid "ops_announce_phase_permissions"
msgstr "Permisos"
