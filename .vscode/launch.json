{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Module",
            "type": "debugpy",
            "request": "launch",
            "module": "misarmy_talkbot"
        },
        {
            "name": "Python: Attach to Remote Bot",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "192.168.100.200",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/misarmy_talkbot",
                    "remoteRoot": "/home/bot/misarmy_talkbot"
                }
            ]
        }
    ]
}
