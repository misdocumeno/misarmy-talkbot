{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker: Attach to Talkbot",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "127.0.0.1",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/src/misarmy_talkbot",
          "remoteRoot": "/home/bot/src/misarmy_talkbot"
        }
      ],
      "justMyCode": false
    },
    {
      "name": "Local: Run module (.env)",
      "type": "debugpy",
      "request": "launch",
      "module": "misarmy_talkbot",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "LOG_LEVEL": "DEBUG",
        "FORENSICS_ENABLED": "true"
      },
      "justMyCode": false
    }
  ]
}
