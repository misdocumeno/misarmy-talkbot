# Copy to .env and fill in values. Compose loads this via env_file.

# Required
DISCORD_TOKEN=

# Lavalink (defaults match docker-compose)
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Shared TTS audio directory (tmpfs mount in compose)
AUDIO_DIR=/tmp/talkbot-audio
AUDIO_TTL_SECONDS=600
AUDIO_JANITOR_INTERVAL_SECONDS=120

# Playback / ops
TTS_MAX_CONCURRENT=4
GRACE_DROP_SECONDS=60
OPS_ANNOUNCE_COOLDOWN_SECONDS=300
METRICS_SNAPSHOT_INTERVAL_SECONDS=300

# Logging (stdout/stderr only; use `docker compose logs` in Docker)
LOG_LEVEL=INFO

# Gettext locale for slash command text and sidebar presence (not global.jsonc)
# LANG=es_AR

# Debug overlay only (docker-compose.debug.yml)
# ENABLE_DEBUGPY=1
# DEBUGPY_PORT=5678
# DEBUGPY_WAIT_FOR_CLIENT=0
